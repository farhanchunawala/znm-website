# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Database
MONGODB_URI=mongodb://localhost:27017/kkms

# Email Configuration
EMAIL_USER="Your App Name <your-email@gmail.com>"
EMAIL_PASS=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS="your-app-password"
SMTP_FROM="Your App Name <your-email@gmail.com>"
ADMIN_EMAIL=admin@yourdomain.com

# JWT Configuration
# IMPORTANT: Generate strong secrets for production!
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Security
BCRYPT_ROUNDS=12